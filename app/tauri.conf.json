{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "CorpoDrone",
  "version": "0.1.0",
  "identifier": "com.corpodrone.app",
  "build": {
    "frontendDist": "web-ui"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "CORPODRONE",
        "width": 1280,
        "height": 800,
        "resizable": true,
        "decorations": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": false,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.ico"
    ]
  }
}
