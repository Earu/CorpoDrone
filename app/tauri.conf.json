{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "CorpoDrone",
  "version": "0.1.0",
  "identifier": "com.corpodrone.app",
  "build": {
    "frontendDist": "web-ui"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "CORPODRONE",
        "width": 1280,
        "height": 800,
        "resizable": true,
        "decorations": true,
        "transparent": true,
        "theme": "Dark",
        "backgroundColor": "#00000000",
        "windowEffects": {
          "effects": ["acrylic", "underWindowBackground"],
          "color": "#070707"
        }
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": false,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "macOS": {
      "minimumSystemVersion": "12.3",
      "entitlements": "./entitlements.plist",
      "infoPlist": "./Info.plist"
    }
  }
}
